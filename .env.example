# Local PostgreSQL connection used by db/connection.py
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mlb_lineup_optimizer
DB_USER=postgres
DB_PASSWORD=your_local_password

# Optional Supabase credentials used by data/migrate_to_supabase.py
SUPABASE_HOST=your-project.supabase.co
SUPABASE_PORT=5432
SUPABASE_DB=postgres
SUPABASE_USER=postgres.your_supabase_user
SUPABASE_PASSWORD=your_supabase_password

# Optional: if you use Streamlit Cloud, put database credentials in
# .streamlit/secrets.toml under [database] instead of .env
